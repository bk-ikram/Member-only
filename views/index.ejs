<!-- views/index.ejs -->
<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
</head>
<body>
  <!-- last name can be viewed if use is admin, or member -->
  <% const canSeeAllAuthors = locals.user?.isadmin || locals.user?.isMember  %>
  <%- include('partials/navBar') %>
  <h1><%= title %></h1>
  <% if (locals.user) {%>
    <p>Click <a href="/new-message">here</a> to create a new message.</p>
  <% } else {%>
    <p>In order to create a new message, please <a href="/login">login</a> first.</p>
  <% };%>
  <% if (locals.user && !locals.user.ismember && !locals.user.isadmin) {%>
      <p>To see usernames, you need to <a href="/?join=true">join our membership</a> first.</p>
  <% } %>
    <% if (locals.membership_failed) {%>
      <p>That is not the right name. Try googling it.</p>
  <% } %>
  <% if (locals.attemptMembership) {%>
      <form action="/become-member" method="post">
        <label for="membership_secret">Please enter the last name of the creator of Jojo's Bizzare adventure.</label>
        <input id="membership_secret" name= "membership_secret" type="text">
        <button>Become a Member</button>
      </form>
  <% } %>
  <% locals.messages.forEach( (m) => { %>
    <!-- last name can be viewed if use is admin, or member, or is own post -->
    <% const canSeeAuthor = canSeeAllAuthors||  m.userid === locals.user?.userid %>
    <% const canDelete = locals.user?.isadmin ||  m.userid === locals.user?.userid %>
    <div>
      <p>
        <h3><%= canSeeAuthor ? m.firstname : "****"%></h3>
        <h4>@<%= canSeeAuthor ? m.username : "****" %> • <%= moment(m.created).fromNow(); %></h4>
        <% if (canDelete) {%>
        <form action="\<%- m.messageid %>\delete" method="post"><button type="submit">Delete</button></form>
        <% }; %>
      </p>
      <p>
        <h4><%= m.title %></h4>
      </p>
      <p>
        <p3><%= m.message %></p3>
      </p>
      <hr>
    </div>
  <% }); %>
</body>
</html>